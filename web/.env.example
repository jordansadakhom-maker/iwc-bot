# ═══ Variables d'environnement du SITE WEB (à mettre sur Vercel) ═══
# Copier ce fichier en .env pour le développement local.
# Le vrai .env n'est JAMAIS commité (voir .gitignore).

# ─── Supabase : connexion Discord (côté navigateur) ───
# Dans Supabase → Project Settings → API. Clé PUBLIABLE (peut être exposée).
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="clé_publiable (sb_publishable_...)"

# ─── Supabase : lecture des données (côté serveur UNIQUEMENT) ───
# Clé SECRÈTE (service_role / sb_secret_...). Sert aux lectures serveur du site.
# Pas de préfixe NEXT_PUBLIC → jamais envoyée au navigateur. À mettre en variable
# Vercel « normale » (secret), pas exposée.
SUPABASE_SERVICE_ROLE_KEY="clé_secrète (sb_secret_...)"

# ─── Verrouillage de l'accès ───
# Laisser "false" pendant toute la mise en place.
# Passer à "true" UNE FOIS la connexion Discord testée : l'accès au site
# devient alors réservé aux membres connectés.
REQUIRE_AUTH="false"

# ─── URL publique du site (facultatif) ───
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ───────────────────────────────────────────────────────────────
# NOTES IMPORTANTES
#  • L'identifiant et le secret Discord ne se mettent PAS ici : ils se
#    configurent dans Supabase → Authentication → Providers → Discord.
#  • La clé service_role sert AUSSI au bot (sur Render). C'est la même clé.
#    Elle ne doit jamais apparaître côté navigateur — d'où l'absence de
#    NEXT_PUBLIC. Le site ne l'utilise que dans le rendu serveur.
#  • DATABASE_URL ne sert qu'aux migrations Prisma en local, pas au runtime.
# ───────────────────────────────────────────────────────────────
