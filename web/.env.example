# ─── Base de données (Supabase → Postgres) ───
# Récupéré dans Supabase : Project Settings → Database → Connection string (URI).
DATABASE_URL="postgresql://postgres:MOT_DE_PASSE@HOTE:5432/postgres"

# ─── Supabase (auth + temps réel + storage) ───
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="clé_anon_publique"
SUPABASE_SERVICE_ROLE_KEY="clé_service_role_SECRETE"

# ─── Connexion Discord (OAuth2) ───
# Créé sur https://discord.com/developers/applications
DISCORD_CLIENT_ID="..."
DISCORD_CLIENT_SECRET="..."
DISCORD_GUILD_ID="l_id_de_ton_serveur"

# URL publique du site (pour la redirection OAuth)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
